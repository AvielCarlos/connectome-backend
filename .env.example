# Connectome Backend Environment Variables
# Copy to .env for local development. Set production values in Railway/Render.

# App / runtime
APP_ENV=production
LOG_LEVEL=INFO
CONNECTOME_API_BASE=https://connectome-api-production.up.railway.app
CONNECTOME_REPO_DIR=/app
CONNECTOME_RUNTIME_DIR=/tmp/connectome
CORS_ORIGINS=["https://atdao.org","https://www.atdao.org","https://avielcarlos.github.io"]
FRONTEND_BASE_URL=https://avielcarlos.github.io/connectome-web

# Database (Railway auto-sets this when you add a PostgreSQL plugin)
DATABASE_URL=postgresql://user:pass@host:5432/connectome

# Redis (Railway auto-sets this when you add a Redis plugin)
REDIS_URL=redis://host:6379

# JWT auth — production must be non-default and at least 32 chars
SECRET_KEY=change-me-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin/internal auth — production must set one non-default 32+ char value
ADMIN_TOKEN=
ADMIN_SECRET=
ADMIN_EMAILS=carlosandromeda8@gmail.com

# Worker authentication
# Production workers should use ORA_JWT_TOKEN or CONNECTOME_WORKER_JWT.
# CONNECTOME_TEST_EMAIL/PASSWORD are dev/test-only login fallback credentials.
ORA_JWT_TOKEN=
CONNECTOME_WORKER_JWT=
CONNECTOME_TEST_EMAIL=
CONNECTOME_TEST_PASSWORD=

# Telegram alerts
ORA_TELEGRAM_TOKEN=
TELEGRAM_BOT_TOKEN=
ORA_TELEGRAM_CHAT_ID=5716959016
TELEGRAM_CHAT_ID=5716959016
DAO_TELEGRAM_CHANNEL_ID=-1003968154861
DAO_TELEGRAM_GROUP_ID=-1003758049811
WORKER_TELEGRAM_CHANNEL_ID=-1003968154861

# GitHub OAuth + webhooks
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://connectome-api-production.up.railway.app/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=

# Google OAuth / Drive / Places
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://connectome-api-production.up.railway.app/api/auth/google/callback
GOOGLE_PLACES_API_KEY=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ORA_MODEL_OVERRIDE=

# Feedback screenshot storage
# Production should use s3/R2-compatible storage; local is dev-only and rejected in production.
FEEDBACK_SCREENSHOT_STORAGE_BACKEND=s3
FEEDBACK_SCREENSHOT_LOCAL_DIR=storage
FEEDBACK_SCREENSHOT_PUBLIC_BASE_URL=
FEEDBACK_SCREENSHOT_MAX_BYTES=5000000
FEEDBACK_SCREENSHOT_S3_BUCKET=
FEEDBACK_SCREENSHOT_S3_REGION=auto
FEEDBACK_SCREENSHOT_S3_ENDPOINT_URL=
FEEDBACK_SCREENSHOT_S3_ACCESS_KEY_ID=
FEEDBACK_SCREENSHOT_S3_SECRET_ACCESS_KEY=

# Monetization / Stripe
FREE_TIER_DAILY_SCREENS=10
PREMIUM_PRICE_CENTS=1299
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_EXPLORER_MONTHLY=
STRIPE_PRICE_EXPLORER_YEARLY=
STRIPE_PRICE_SOVEREIGN_MONTHLY=
STRIPE_PRICE_SOVEREIGN_YEARLY=

# SMTP customer/service delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Discovery providers
SERPAPI_KEY=
EVENTBRITE_TOKEN=

# Railway self-management / deploy agent
RAILWAY_API_TOKEN=
RAILWAY_SERVICE_ID=088d77ed-a707-4dc4-af68-866bf99a1d63
RAILWAY_PROJECT_ID=ab771963-d525-4b99-85e4-f084f065b0ae
RAILWAY_ENVIRONMENT_ID=

# WorldAgent
WORLD_AGENT_ENABLED=true

# Ora brain backup freshness
ORA_BACKUP_SCHEDULER_ENABLED=true
ORA_IDENTITY_BACKUP_INTERVAL_SECONDS=3600
ORA_BACKUP_FRESHNESS_CHECK_SECONDS=1800
ORA_EVENT_BACKUP_DEBOUNCE_SECONDS=900
