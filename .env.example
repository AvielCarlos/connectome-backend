# Connectome Backend Environment Variables
# Copy to .env and fill in your values

# Database (Railway auto-sets this when you add a PostgreSQL plugin)
DATABASE_URL=postgresql://user:pass@host:5432/connectome

# Redis (Railway auto-sets this when you add a Redis plugin)
REDIS_URL=redis://host:6379

# OpenAI (optional — falls back to intelligent mock if not set)
OPENAI_API_KEY=sk-...

# Google Places API (enables real venue search)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Feedback screenshot storage
# local writes to FEEDBACK_SCREENSHOT_LOCAL_DIR for dev; s3 supports AWS S3, Cloudflare R2, etc.
FEEDBACK_SCREENSHOT_STORAGE_BACKEND=local
FEEDBACK_SCREENSHOT_LOCAL_DIR=storage
FEEDBACK_SCREENSHOT_PUBLIC_BASE_URL=
FEEDBACK_SCREENSHOT_MAX_BYTES=5000000
FEEDBACK_SCREENSHOT_S3_BUCKET=
FEEDBACK_SCREENSHOT_S3_REGION=auto
FEEDBACK_SCREENSHOT_S3_ENDPOINT_URL=
FEEDBACK_SCREENSHOT_S3_ACCESS_KEY_ID=
FEEDBACK_SCREENSHOT_S3_SECRET_ACCESS_KEY=

# JWT Auth
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=["https://atdao.org","https://connectome-backend.up.railway.app","exp://connectome-backend.up.railway.app"]

# Monetization
FREE_TIER_DAILY_SCREENS=10
PREMIUM_PRICE_CENTS=1299

# WorldAgent
WORLD_AGENT_ENABLED=true
